.type-switch {
  display: flex;
  justify-content: center;
  padding: 10rpx !important;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: var(--color-text-sub);
  border-radius: var(--radius-btn);
  font-weight: bold;
}

.type-item.active {
  background-color: var(--color-secondary);
  color: var(--color-text-main);
  border: var(--border-thick);
  box-shadow: inset 0 -4rpx 0 rgba(0,0,0,0.1);
}

.amount-container {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx !important;
}

.currency-symbol {
  font-size: 60rpx;
  font-weight: 900;
  margin-right: 20rpx;
  color: var(--color-text-main);
}

.amount-input {
  flex: 1;
  font-size: 80rpx;
  height: 100rpx;
  font-weight: 900;
  color: var(--color-text-main);
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.category-item.active {
  opacity: 1;
}

.category-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-avatar);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  background-color: var(--color-bg);
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.category-item.active .category-icon-wrapper {
  background-color: var(--color-accent);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
}

.category-icon {
  font-size: 50rpx;
}

.category-name {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--color-text-main);
}

.remark-container {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx !important;
}

.remark-label {
  width: 100rpx;
  font-weight: bold;
  color: var(--color-text-main);
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-main);
}

.save-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
}

.voice-container {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
}

.voice-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-avatar);
  background-color: var(--color-secondary);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.voice-emoji {
  font-size: 60rpx;
}

.voice-btn.recording {
  background-color: var(--color-danger);
  transform: scale(1.1);
  box-shadow: 0 0 20rpx rgba(239, 71, 111, 0.5);
}

.voice-tips {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--color-text-sub);
}
