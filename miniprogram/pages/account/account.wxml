<view class="container">
  <!-- Type Switcher -->
  <view class="type-switch card">
    <view class="type-item bounce-click {{currentType === 'expense' ? 'active' : ''}}" hover-class="bounce-active" bindtap="switchType" data-type="expense">支出</view>
    <view class="type-item bounce-click {{currentType === 'income' ? 'active' : ''}}" hover-class="bounce-active" bindtap="switchType" data-type="income">收入</view>
  </view>

  <!-- Amount Input -->
  <view class="amount-container card">
    <text class="currency-symbol">¥</text>
    <input 
      class="amount-input" 
      type="digit" 
      placeholder="0.00" 
      value="{{amount}}" 
      bindinput="onAmountInput" 
    />
  </view>

  <!-- Category Selection -->
  <view class="category-container card">
    <view class="category-grid">
      <view 
        class="category-item bounce-click {{currentCategory === item.name ? 'active' : ''}}" 
        hover-class="bounce-active"
        wx:for="{{categories[currentType]}}" 
        wx:key="name"
        bindtap="selectCategory"
        data-category="{{item.name}}"
      >
        <view class="category-icon-wrapper">
          <view class="category-icon">{{item.icon}}</view>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- Remark Input -->
  <view class="remark-container card">
    <text class="remark-label">备注</text>
    <input 
      class="remark-input" 
      type="text" 
      placeholder="写点什么吧..." 
      value="{{remark}}" 
      bindinput="onRemarkInput" 
      maxlength="50"
    />
  </view>

  <!-- Action Buttons -->
  <view class="action-buttons">
    <button class="btn-primary save-btn bounce-click" hover-class="bounce-active" bindtap="saveRecord">保存记录</button>
  </view>

  <!-- Voice Input Area -->
  <view class="voice-container">
    <view 
      class="voice-btn bounce-click {{isRecording ? 'recording' : ''}}" 
      hover-class="bounce-active"
      bindlongpress="startRecord" 
      bindtouchend="stopRecord"
    >
      <text class="voice-emoji">🎤</text>
    </view>
    <text class="voice-tips">{{isRecording ? '松开结束' : '长按语音输入备注'}}</text>
  </view>
</view>
