.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: var(--color-bg);
  position: relative;
  overflow: hidden;
}

.login-card {
  width: 85%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  z-index: 10;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  background-color: var(--color-secondary);
  border-radius: var(--radius-avatar);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--color-text-main);
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: var(--color-text-sub);
  font-weight: bold;
}

.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.input-group {
  width: 100%;
  display: flex;
  align-items: center;
  background-color: var(--color-bg);
  border: var(--border-thick);
  border-radius: var(--radius-btn);
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: inset 0 4rpx 0px rgba(0,0,0,0.05);
  box-sizing: border-box;
}

.input-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.custom-input {
  flex: 1;
  font-size: 32rpx;
  color: var(--color-text-main);
  font-weight: bold;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background-color: var(--color-primary);
  margin-bottom: 24rpx;
}

.register-btn {
  width: 100%;
  height: 96rpx;
  background-color: var(--color-secondary);
  color: var(--color-text-main);
  border-radius: var(--radius-btn);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.login-tips {
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-top: 10rpx;
}

/* 装饰性元素 */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  background-color: var(--color-secondary);
  opacity: 0.5;
  z-index: 1;
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -50rpx;
  right: -100rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: 100rpx;
  left: -50rpx;
  background-color: var(--color-accent);
}