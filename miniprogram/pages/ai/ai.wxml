<view class="container">
  <!-- Month Picker -->
  <view class="month-picker-container card bounce-click" hover-class="bounce-active">
    <picker mode="date" fields="month" value="{{currentMonth}}" end="{{currentMonth}}" bindchange="onMonthChange">
      <view class="picker-inner">
        <text class="month-text">✨ {{currentMonth}} 智能分析 ✨</text>
        <text class="picker-icon">▼</text>
      </view>
    </picker>
  </view>

  <!-- AI Advice Carousel -->
  <view class="advice-container" wx:if="{{advices.length > 0}}">
    <swiper 
      class="advice-swiper" 
      indicator-dots="true" 
      indicator-color="rgba(45, 49, 66, 0.2)" 
      indicator-active-color="#FF6B6B"
      autoplay="true"
      interval="5000"
      duration="500"
      circular="true"
    >
      <swiper-item wx:for="{{advices}}" wx:key="*this">
        <view class="advice-card bounce-click" hover-class="bounce-active">
          <!-- Cartoon Style Header Area -->
          <view class="advice-header" style="background-color: {{index % 2 === 0 ? '#4ECDC4' : '#FFE66D'}}">
             <view class="advice-emoji">{{index % 2 === 0 ? '🤖' : '🦉'}}</view>
             <text class="advice-title">AI 小助手建议</text>
          </view>
          
          <view class="advice-content">
            <text class="advice-text">{{item}}</text>
          </view>
          
          <!-- Decorative Elements -->
          <view class="deco-circle circle-1"></view>
          <view class="deco-circle circle-2"></view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- Empty State -->
  <view class="empty-state card" wx:if="{{advices.length === 0}}">
    <view class="empty-icon">💤</view>
    <text class="empty-text">本月还没有分析数据哦</text>
  </view>
</view>
