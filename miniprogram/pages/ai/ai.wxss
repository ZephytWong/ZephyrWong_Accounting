.bottom-actions {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.logout-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 900;
  background-color: var(--color-danger);
  color: #fff;
  border-radius: var(--radius-btn);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-picker-container {
  display: flex;
  justify-content: center;
  padding: 20rpx !important;
  background-color: var(--color-primary);
}

.picker-inner {
  display: flex;
  align-items: center;
}

.month-text {
  font-size: 36rpx;
  font-weight: 900;
  margin-right: 10rpx;
  color: #FFFFFF;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.2);
}

.picker-icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

.advice-container {
  margin-top: 20rpx;
}

.advice-swiper {
  height: 800rpx;
}

.advice-card {
  width: 90%;
  height: 85%;
  margin: 0 auto;
  margin-top: 20rpx;
  background-color: var(--color-card-bg);
  border-radius: var(--radius-card);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

.advice-header {
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: var(--border-thick);
  position: relative;
  overflow: hidden;
}

.advice-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  text-shadow: 4rpx 4rpx 0 rgba(0,0,0,0.1);
  z-index: 2;
}

.advice-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #2D3142;
  z-index: 2;
}

.advice-content {
  flex: 1;
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-card-bg);
  position: relative;
  z-index: 2;
}

.advice-text {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-main);
  line-height: 1.8;
  text-align: center;
}

/* 装饰性元素 */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  z-index: 1;
}

.circle-1 {
  width: 150rpx;
  height: 150rpx;
  top: -20rpx;
  right: -20rpx;
}

.circle-2 {
  width: 80rpx;
  height: 80rpx;
  bottom: 20rpx;
  left: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 !important;
  margin-top: 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-sub);
}
