.month-picker-container {
  display: flex;
  justify-content: center;
  padding: 20rpx !important;
  background-color: var(--color-secondary);
}

.picker-inner {
  display: flex;
  align-items: center;
}

.month-text {
  font-size: 36rpx;
  font-weight: 900;
  margin-right: 10rpx;
  color: var(--color-text-main);
}

.picker-icon {
  font-size: 24rpx;
  color: var(--color-text-main);
}

.stats-container {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

.stat-card {
  width: 48%;
  padding: 20rpx !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx !important;
}

.balance-card {
  width: 100%;
  background-color: var(--color-secondary);
}

.expense-card {
  background-color: #FF99C8; /* 卡通粉 */
}

.income-card {
  background-color: var(--color-success);
}

.stat-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #2D3142;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 900;
  color: #2D3142;
}

.chart-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 30rpx;
  width: 100%;
  text-align: left;
  color: var(--color-text-main);
}

.pie-canvas {
  width: 250px;
  height: 250px;
  margin-bottom: 40rpx;
}

.category-list {
  width: 100%;
}

.category-list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background-color: var(--color-bg);
  border: var(--border-thick);
  border-radius: var(--radius-btn);
  box-shadow: var(--shadow-cartoon);
}

.category-color {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.category-list-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-main);
}

.category-list-value {
  font-size: 32rpx;
  font-weight: 900;
  margin-right: 20rpx;
  color: var(--color-text-main);
}

.category-percent-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 4rpx solid #2D3142;
}

.category-list-percent {
  font-size: 24rpx;
  font-weight: bold;
  color: #2D3142;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 !important;
  background-color: var(--color-card-bg);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-sub);
}
