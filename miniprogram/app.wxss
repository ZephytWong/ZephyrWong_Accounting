/**app.wxss**/
@import './theme-cartoon.wxss';

page {
  background-color: var(--color-bg);
  font-size: 28rpx;
  color: var(--color-text-main);
  font-family: var(--font-cartoon);
  line-height: 1.5;
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* =========================================
   全局组件重写 - 卡通卡片
   ========================================= */
.card {
  background-color: var(--color-card-bg);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  position: relative;
  overflow: hidden;
}

/* =========================================
   全局组件重写 - 卡通按钮
   ========================================= */
.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-btn);
  border: var(--border-thick);
  box-shadow: var(--shadow-cartoon);
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.2);
  /* 高光层 */
  background-image: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 40%);
}

.btn-primary::after {
  display: none;
}

/* =========================================
   全局动画 - 弹性缩放交互
   使用 will-change 和 transform 确保高 FPS
   ========================================= */
.bounce-click {
  transition: transform 0.15s cubic-bezier(0.68, -0.55, 0.27, 1.55);
  will-change: transform;
}

.bounce-active {
  transform: scale(0.95);
}

/* 颜色辅助类 */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-secondary); }
.text-accent { color: var(--color-accent); }
